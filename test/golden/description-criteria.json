{
  "_comment": "Quality criteria for LLM-generated descriptions. Each entry defines what a GOOD description must look like for semantic search to work. These are evaluated against the Worker's /ingest response. Descriptions are non-deterministic, so we use keyword presence and anti-pattern checks rather than exact matching.",

  "badPhrases": [
    "This function",
    "The function",
    "This code",
    "The code",
    "Here is a description",
    "Here is a",
    "This is a function",
    "This is a method",
    "This class"
  ],

  "chunks": {
    "hashPassword": {
      "fixture": "mini-api/src/auth.ts",
      "domain": "password security, hashing, authentication",
      "minLength": 60,
      "mustContainAny": ["password", "hash", "salt", "hmac", "security", "credential", "encrypt"]
    },
    "verifyPassword": {
      "fixture": "mini-api/src/auth.ts",
      "domain": "password verification, authentication",
      "minLength": 60,
      "mustContainAny": ["password", "verify", "compare", "check", "authentication", "hash", "credential"]
    },
    "generateToken": {
      "fixture": "mini-api/src/auth.ts",
      "domain": "token generation, session management, authentication",
      "minLength": 60,
      "mustContainAny": ["token", "session", "generate", "sign", "jwt", "authentication", "expir"]
    },
    "validateToken": {
      "fixture": "mini-api/src/auth.ts",
      "domain": "token validation, session verification",
